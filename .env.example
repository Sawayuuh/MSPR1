# --- Supabase CLOUD (recommandé prod) ---
# Dashboard : https://supabase.com/dashboard → Project Settings → API & Database
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...          # anon / public
SUPABASE_SERVICE_KEY=eyJ...  # service_role (garde secrète)
# URI Postgres : Project Settings → Database → Connection string (mode URI). Mot de passe = celui fixé à la création du projet.
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-eu-xxx.pooler.supabase.com:6543/postgres
# Même page API → JWT Secret (Legacy ou JWT) — copier la valeur intégrale, sans guillemets.
JWT_SECRET=your-supabase-jwt-secret

# --- Supabase LOCAL (dev uniquement, avec `supabase start` + Docker) ---
# SUPABASE_URL=http://host.docker.internal:54321
# SUPABASE_KEY=<copier "anon" depuis `supabase status`>
# SUPABASE_SERVICE_KEY=<copier "service_role" depuis `supabase status`>
# DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres
# JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Port publié sur l’hôte pour le conteneur Next.js. Défaut compose : 8000 (API MSPR sur 8001). Ex. WEB_PORT=8000 si libre.
WEB_PORT=8000

# Planification ETL — expression cron 5 champs (UTC). Défaut : lundi à 02h00.
# Exemples : "0 2 * * 1" = lundi 02h00 | "0 */6 * * *" = toutes les 6h | "0 3 * * *" = chaque nuit 03h00
ETL_SCHEDULE=0 2 * * 1

# Kaggle — requis pour le téléchargement automatique des datasets par l'ETL
# Obtenez vos credentials sur https://www.kaggle.com/settings → API → Legacy API Credentials
KAGGLE_USERNAME=votre_pseudo_kaggle
KAGGLE_KEY=votre_clé_api_kaggle

# Comptes admin (emails séparés par des virgules) : à chaque GET /api/v1/auth/me, l’API met app_role=admin
# sur la ligne public.utilisateurs si l’email correspond. Il faut donc une ligne dans utilisateurs + cette variable
# (avec Docker : elle est passée au conteneur api via docker-compose).
ADMIN_EMAILS=admin@example.com,autre@example.com
